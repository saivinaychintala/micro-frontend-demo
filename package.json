{
  "name": "micro-frontend-demo",
  "version": "1.0.0",
  "description": "Micro-Frontend Architecture Demo with Next.js and Module Federation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter host dev\" \"pnpm --filter dashboard dev\" \"pnpm --filter settings dev\"",
    "dev:host": "pnpm --filter host dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:settings": "pnpm --filter settings dev",
    "build": "pnpm -r build",
    "build:host": "pnpm --filter host build",
    "build:dashboard": "pnpm --filter dashboard build",
    "build:settings": "pnpm --filter settings build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "type-check": "pnpm -r type-check"
  },
  "keywords": [
    "micro-frontend",
    "module-federation",
    "nextjs",
    "monorepo",
    "webpack",
    "tailwindcss"
  ],
  "author": "Vinay Chintala",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
